# md2pdf E-Library Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# ADAPTER CONFIGURATION
# ===========================================
# Options: 'supabase' or 'local'
ADAPTER_PROVIDER=supabase

# ===========================================
# SUPABASE CONFIGURATION (required if ADAPTER_PROVIDER=supabase)
# ===========================================
# Find these in your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# Service key (only needed for setup script)
# SUPABASE_SERVICE_KEY=your-service-role-key

# ===========================================
# AUTHENTICATION
# ===========================================
# Enable user authentication (true/false)
AUTH_ENABLED=true

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Port to run the server on (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development
