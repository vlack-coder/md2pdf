# Server Configuration
PORT=9990
HOST=0.0.0.0
NODE_ENV=development

# Adapter Provider: 'local' or 'supabase'
ADAPTER_PROVIDER=local

# Authentication (optional - disabled by default)
AUTH_ENABLED=false

# Supabase Configuration (when using Supabase adapter)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key  # Optional, for admin operations

# Local Adapter Configuration (when using local adapter)
DATA_DIR=./data
STORAGE_DIR=./storage
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Storage Bucket Name
STORAGE_BUCKET=library