{
  "name": "md2pdf",
  "version": "2.1.0",
  "description": "E-Library with markdown-to-PDF/HTML converter, Night Owl theme, and multi-provider storage support",
  "type": "module",
  "bin": {
    "md2pdf": "./md2pdf"
  },
  "scripts": {
    "convert": "node convert-to-pdf.mjs",
    "serve": "node server.mjs",
    "start": "node server.mjs",
